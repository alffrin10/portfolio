dist/
dist-ssr/
build/
bin/
obj/

# --- Environment & Secrets ---
# Crucial: Protects your private keys and researcher data
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# --- Vercel Specific ---
# Vercel creates this folder for project linking
.vercel

# --- Editor & IDEs ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# --- Operating System Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Engineering/Robotics Extras ---
# If you use Python for GPR data processing, ignore these:
__pycache__/
*.py[cod]
*$py.class